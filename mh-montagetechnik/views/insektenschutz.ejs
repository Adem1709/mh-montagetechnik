<%- include("partials/head") %>
<%- include("partials/header") %>

<main class="section">
  <div class="container">

    <div class="section__head">
      <h1>Insektenschutz</h1>
      <p class="muted">
        Maßgeschneiderte Insektenschutz-Systeme für Fenster und Türen – dezent, praktisch und langlebig.
      </p>
    </div>

    <section class="category-hero reveal">
      <div class="category-hero__media">
        <img src="/public/img/services/insektenschutz.jpg" alt="Insektenschutz">
      </div>

      <div class="category-hero__content">
        <span class="tag">Insektenschutz Systeme</span>
        <h2>Sauberer Schutz für Fenster und Türen</h2>
        <p>
          Wir bieten passgenaue Insektenschutz-Lösungen für Wohnhäuser und Objekte – unauffällig integriert und praktisch im Alltag.
        </p>

        <div class="hero-card__checks">
          <div>✓ Saubere Montage</div>
          <div>✓ Hochwertige Systeme</div>
          <div>✓ Professionelle Ausführung</div>
        </div>

        <div class="hero-card__actions" style="margin-top:18px;">
          <a class="btn btn--primary" href="/kontakt#angebot">Angebot anfordern</a>
          <a class="btn btn--ghost" href="/galerie">Projekte ansehen</a>
        </div>
      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="section__head">
        <h2>Insektenschutz Lösungen</h2>
        <p class="muted">Die wichtigsten Systeme im Überblick.</p>
      </div>

      <div class="services-grid reveal">

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Fenster Insektenschutz">
  <div class="service-content">
    <h3>Fenster Insektenschutz</h3>
    <p>Passgenaue Systeme für klassische Fensterlösungen.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Tür Insektenschutz">
  <div class="service-content">
    <h3>Tür Insektenschutz</h3>
    <p>Praktische Schutzsysteme für Balkon- und Terrassentüren.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Schiebeanlagen">
  <div class="service-content">
    <h3>Schiebeanlagen</h3>
    <p>Komfortable Lösungen für große Öffnungen und Schiebeelemente.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Spannrahmen">
  <div class="service-content">
    <h3>Spannrahmen</h3>
    <p>Dezente und einfache Systeme für viele Fensterarten.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Drehrahmen">
  <div class="service-content">
    <h3>Drehrahmen</h3>
    <p>Flexible Systeme für häufig genutzte Tür- und Fensterbereiche.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/insektenschutz.jpg" alt="Sonderlösungen">
  <div class="service-content">
    <h3>Sonderlösungen</h3>
    <p>Individuelle Insektenschutz-Systeme abgestimmt auf Ihr Projekt.</p>
  </div>
</article>

      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="premium-cta">
        <div>
          <span class="section-kicker">Beratung & Angebot</span>
          <h2>Sie planen Insektenschutz-Systeme?</h2>
          <p class="muted">Wir beraten Sie zu passenden Lösungen für Fenster, Türen und Schiebeelemente.</p>
        </div>

        <div class="premium-cta__actions">
          <a class="btn btn--primary" href="/kontakt#angebot">Jetzt anfragen</a>
          <a class="btn btn--ghost" href="/produkte">Weitere Produkte</a>
        </div>
      </div>
    </section>

  </div>
</main>

<%- include("partials/footer") %>
