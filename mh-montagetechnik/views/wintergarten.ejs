<%- include("partials/head") %>
<%- include("partials/header") %>

<main class="section">
  <div class="container">

    <div class="section__head">
      <h1>Wintergärten</h1>
      <p class="muted">
        Moderne Wintergarten-Lösungen mit viel Licht, hochwertiger Ausführung und professioneller Montage.
      </p>
    </div>

    <section class="category-hero reveal">
      <div class="category-hero__media">
        <img src="/public/img/services/wintergarten.jpg" alt="Wintergärten">
      </div>

      <div class="category-hero__content">
        <span class="tag">Wintergarten Systeme</span>
        <h2>Mehr Licht, mehr Raum, mehr Wohnqualität</h2>
        <p>
          Wir realisieren moderne Wintergarten-Lösungen mit klarer Optik, hochwertigen Materialien und sauberer Integration in Ihr Zuhause.
        </p>

        <div class="hero-card__checks">
          <div>✓ Saubere Montage</div>
          <div>✓ Hochwertige Systeme</div>
          <div>✓ Professionelle Ausführung</div>
        </div>

        <div class="hero-card__actions" style="margin-top:18px;">
          <a class="btn btn--primary" href="/kontakt#angebot">Angebot anfordern</a>
          <a class="btn btn--ghost" href="/galerie">Projekte ansehen</a>
        </div>
      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="section__head">
        <h2>Wintergarten Lösungen</h2>
        <p class="muted">Die wichtigsten Ausführungen im Überblick.</p>
      </div>

      <div class="services-grid reveal">

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Aluminium Wintergärten">
  <div class="service-content">
    <h3>Aluminium Wintergärten</h3>
    <p>Moderne, stabile Konstruktionen mit klarer Linienführung.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Glas-Systeme">
  <div class="service-content">
    <h3>Glas-Systeme</h3>
    <p>Großzügige Lichtflächen mit hochwertiger Verglasung.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Schiebeelemente">
  <div class="service-content">
    <h3>Schiebeelemente</h3>
    <p>Praktische Öffnungslösungen mit modernem Komfort.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Anbau Wintergärten">
  <div class="service-content">
    <h3>Anbau Wintergärten</h3>
    <p>Passgenaue Lösungen für bestehende Gebäude.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Überdachungen">
  <div class="service-content">
    <h3>Überdachungen</h3>
    <p>Elegante Glas- und Dachsysteme für Außenbereiche.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/wintergarten.jpg" alt="Sonderlösungen">
  <div class="service-content">
    <h3>Sonderlösungen</h3>
    <p>Individuelle Konstruktionen abgestimmt auf Ihr Projekt.</p>
  </div>
</article>

      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="premium-cta">
        <div>
          <span class="section-kicker">Beratung & Angebot</span>
          <h2>Sie planen einen Wintergarten?</h2>
          <p class="muted">Wir beraten Sie zu Systemen, Verglasung, Design und professioneller Umsetzung.</p>
        </div>

        <div class="premium-cta__actions">
          <a class="btn btn--primary" href="/kontakt#angebot">Jetzt anfragen</a>
          <a class="btn btn--ghost" href="/produkte">Weitere Produkte</a>
        </div>
      </div>
    </section>

  </div>
</main>

<%- include("partials/footer") %>
