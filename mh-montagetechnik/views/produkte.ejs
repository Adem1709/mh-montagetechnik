<% /* PRODUKTE PAGE
   Kartat dhe layout ndryshohen te pages.css + components.css
*/ %>
<%- include("partials/head") %>
<%- include("partials/header") %>
<main class="section">
  <div class="container">

    <div class="section__head">
      <h1>Unsere Leistungen</h1>
      <p class="muted">
        Entdecken Sie unsere Produktbereiche – modern, hochwertig und professionell montiert.
      </p>
    </div>

    <div class="services-grid reveal">

      <a href="/fenster" class="service-item">
        <img src="/public/img/services/fenster.jpg" alt="Fenster">
        <div class="service-content">
          <h3>Fenster</h3>
          <p>PVC- und Aluminiumfenster – energieeffizient, modern und hochwertig.</p>
        </div>
      </a>

      <a href="/tueren" class="service-item">
        <img src="/public/img/services/tueren.jpg" alt="Türen">
        <div class="service-content">
          <h3>Türen</h3>
          <p>Haustüren und Innentüren mit Fokus auf Sicherheit, Design und Langlebigkeit.</p>
        </div>
      </a>

      <a href="/rolllaeden" class="service-item">
        <img src="/public/img/services/rollladen.jpg" alt="Rollläden">
        <div class="service-content">
          <h3>Rollläden & Jalousien</h3>
          <p>Sichtschutz, Wärmeschutz und moderne Nachrüstung.</p>
        </div>
      </a>

      <a href="/wintergarten" class="service-item">
        <img src="/public/img/services/wintergarten.jpg" alt="Wintergärten">
        <div class="service-content">
          <h3>Wintergärten</h3>
          <p>Moderne Lösungen mit viel Licht und hochwertiger Ausführung.</p>
        </div>
      </a>

      <a href="/gelaender" class="service-item">
        <img src="/public/img/services/gelaender.jpg" alt="Geländer">
        <div class="service-content">
          <h3>Geländer & Absturzsicherung</h3>
          <p>Sichere und elegante Lösungen für Glas-, Balkon- und Fensterbereiche.</p>
        </div>
      </a>

      <a href="/insektenschutz" class="service-item">
        <img src="/public/img/services/insektenschutz.jpg" alt="Insektenschutz">
        <div class="service-content">
          <h3>Insektenschutz</h3>
          <p>Passgenaue Systeme für Fenster und Türen – praktisch und langlebig.</p>
        </div>
      </a>

    </div>

  </div>
</main>


<%- include("partials/cookie-banner") %>
<%- include("partials/footer") %>
