<%- include("partials/head") %>
<%- include("partials/header") %>

<main class="section">
  <div class="container">

    <div class="section__head">
      <h1>Geländer & Absturzsicherung</h1>
      <p class="muted">
        Sichere und elegante Lösungen für Balkon-, Glas- und Fensterbereiche – funktional und hochwertig umgesetzt.
      </p>
    </div>

    <section class="category-hero reveal">
      <div class="category-hero__media">
        <img src="/public/img/services/gelaender.jpg" alt="Geländer & Absturzsicherung">
      </div>

      <div class="category-hero__content">
        <span class="tag">Sicherheits Systeme</span>
        <h2>Sichere Lösungen mit moderner Optik</h2>
        <p>
          Wir bieten hochwertige Geländer- und Absturzsicherungs-Systeme für Wohn- und Objektbereiche – sicher, langlebig und optisch sauber integriert.
        </p>

        <div class="hero-card__checks">
          <div>✓ Saubere Montage</div>
          <div>✓ Hochwertige Systeme</div>
          <div>✓ Professionelle Ausführung</div>
        </div>

        <div class="hero-card__actions" style="margin-top:18px;">
          <a class="btn btn--primary" href="/kontakt#angebot">Angebot anfordern</a>
          <a class="btn btn--ghost" href="/galerie">Projekte ansehen</a>
        </div>
      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="section__head">
        <h2>Systeme im Überblick</h2>
        <p class="muted">Die wichtigsten Geländer- und Sicherungslösungen.</p>
      </div>

      <div class="services-grid reveal">

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Glasgeländer">
  <div class="service-content">
    <h3>Glasgeländer</h3>
    <p>Moderne und elegante Lösungen mit hochwertiger Wirkung.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Balkongeländer">
  <div class="service-content">
    <h3>Balkongeländer</h3>
    <p>Sichere Systeme für Balkon und Außenbereiche.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Absturzsicherung Fenster">
  <div class="service-content">
    <h3>Absturzsicherung Fenster</h3>
    <p>Schutzlösungen für bodentiefe Fenster und Glasflächen.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Metallgeländer">
  <div class="service-content">
    <h3>Metallgeländer</h3>
    <p>Robuste und langlebige Systeme für viele Einsatzbereiche.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Innenbereich">
  <div class="service-content">
    <h3>Innenbereich</h3>
    <p>Geländerlösungen mit moderner Gestaltung für innen.</p>
  </div>
</article>

        <article class="service-item service-item--static">
  <img src="/public/img/services/gelaender.jpg" alt="Sonderlösungen">
  <div class="service-content">
    <h3>Sonderlösungen</h3>
    <p>Individuelle Sicherungssysteme passend zu Ihrem Projekt.</p>
  </div>
</article>

      </div>
    </section>

    <section class="section" style="padding-bottom:0;">
      <div class="premium-cta">
        <div>
          <span class="section-kicker">Beratung & Angebot</span>
          <h2>Sie planen Geländer oder Absturzsicherung?</h2>
          <p class="muted">Wir beraten Sie zu sicheren und optisch hochwertigen Lösungen für Ihr Projekt.</p>
        </div>

        <div class="premium-cta__actions">
          <a class="btn btn--primary" href="/kontakt#angebot">Jetzt anfragen</a>
          <a class="btn btn--ghost" href="/produkte">Weitere Produkte</a>
        </div>
      </div>
    </section>

  </div>
</main>

<%- include("partials/footer") %>
